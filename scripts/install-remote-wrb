#!/usr/bin/env bash

set -euo pipefail

default_bundle_uri='wsh://local/~/Documents/Codex/2026-05-07/python-node-js-ui-html-js/dist/wrb-remote-source.tgz'
bundle_uri="${WRB_BUNDLE_URI:-$default_bundle_uri}"
install_root="${WRB_INSTALL_ROOT:-$HOME/.local/share/wave-repo-browser}"
bin_dir="${WRB_BIN_DIR:-$HOME/.local/bin}"
port="${WRB_REMOTE_PORT:-17876}"

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

ensure_bun() {
  if command -v bun >/dev/null 2>&1; then
    return
  fi

  if [ "${WRB_INSTALL_BUN:-1}" != "1" ]; then
    echo "bun is not installed. Install Bun or rerun with WRB_INSTALL_BUN=1." >&2
    exit 1
  fi

  need_cmd curl
  echo "Installing Bun into ~/.bun ..."
  curl -fsSL https://bun.sh/install | bash
  export PATH="$HOME/.bun/bin:$PATH"

  if ! command -v bun >/dev/null 2>&1; then
    echo "Bun installation finished, but bun is still not on PATH." >&2
    echo "Try: export PATH=\"\$HOME/.bun/bin:\$PATH\"" >&2
    exit 1
  fi
}

if [ -z "${WAVETERM:-}" ]; then
  echo "Warning: WAVETERM is not set. This installer is intended to run inside a Wave remote shell." >&2
fi

need_cmd wsh
need_cmd tar
ensure_bun

tmp_dir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmp_dir"
}
trap cleanup EXIT

archive="$tmp_dir/wrb-remote-source.tgz"

echo "Copying bundle from local Wave host:"
echo "  $bundle_uri"
wsh file cp "$bundle_uri" "$archive"

rm -rf "$install_root/src"
mkdir -p "$install_root/src" "$install_root/bin" "$bin_dir"

tar -xzf "$archive" -C "$install_root/src"

cd "$install_root/src"
bun install
bun run build

cp dist/wrb "$install_root/bin/wrb-bin"
chmod +x "$install_root/bin/wrb-bin"

cat >"$bin_dir/wrb" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
exec "$HOME/.local/share/wave-repo-browser/bin/wrb-bin" "$@"
EOF

chmod +x "$bin_dir/wrb"

echo
echo "Installed wrb:"
echo "  $bin_dir/wrb"
echo
echo "Remote default mode listens on:"
echo "  0.0.0.0:$port"
echo
if ! printf '%s' ":$PATH:" | grep -q ":$bin_dir:"; then
  echo "Add this to your shell profile if needed:"
  echo "  export PATH=\"$bin_dir:\$PATH\""
  echo
fi
echo "Try:"
echo "  wrb"
