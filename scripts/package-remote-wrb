#!/usr/bin/env zsh

set -euo pipefail

script_dir="${0:A:h}"
repo_dir="${script_dir:h}"
bundle="$repo_dir/dist/wrb-remote-source.tgz"

cd "$repo_dir"

mkdir -p dist
bun run embed >/dev/null

tar \
  --exclude='node_modules' \
  --exclude='dist' \
  -czf "$bundle" \
  package.json \
  bun.lock \
  README.md \
  src \
  scripts/embed-codicons.mjs \
  scripts/wrb-launcher

echo "Created: $bundle"

case "$bundle" in
  "$HOME"/*)
    rel="${bundle#$HOME/}"
    echo "Remote URI: wsh://local/~/$rel"
    ;;
  *)
    echo "Remote URI: wsh://local$bundle"
    ;;
esac
